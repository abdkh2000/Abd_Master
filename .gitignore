# LaTeX build outputs
build/*
!build/.gitkeep
*.aux
*.bbl
*.bcf
*.blg
*.fdb_latexmk
*.fls
*.idx
*.ilg
*.ind
*.lof
*.log
*.lot
*.out
*.run.xml
*.synctex.gz
*.toc
*.xdv
*.nav
*.snm
*.vrb

# PDFs generated from source
*.pdf
!figures/**/*.pdf

# Python
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/
.venv/
venv/
env/

# Data and generated artifacts
data/raw/
data/interim/
data/processed/
template_output/
*.tmp
*.temp
*.bak
*.swp
*.swo
~$*

# Secrets and local environment files
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
secrets/

# VS Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# OS files
.DS_Store
Thumbs.db
desktop.ini
